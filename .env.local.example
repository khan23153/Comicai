# Google Gemini API Key
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Replicate API Token (for image generation)
# Get yours at: https://replicate.com/
REPLICATE_API_TOKEN=your_replicate_api_token_here

# (Optional) Override the Replicate model version for image generation
# Defaults to Stable Diffusion v1.5 if not set
# REPLICATE_MODEL_VERSION=ac732df83cea7fff18b8472768c88ad041fa750ff7682a21affe81863cbe77e4
