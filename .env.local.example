# Google Gemini API Key
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Image Generation Provider: "replicate" or "openai"
IMAGE_PROVIDER=replicate

# Replicate API Key (used when IMAGE_PROVIDER=replicate)
# Get your key from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here

# OpenAI API Key (used when IMAGE_PROVIDER=openai for DALL-E 3)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
